# ==========================================
# VoiceTL (Voice Translation Live) Settings
# ==========================================

# Gemini API-Key (Kann auch im Terminal via `export GEMINI_API_KEY="..."` gesetzt werden)
# GEMINI_API_KEY=your_gemini_api_key_here

# Zielsprachen (Language Codes wie en, de, es, fr, etc.)
OUT_TARGET_LANG=en
IN_TARGET_LANG=de

# Stille-Erkennung / Lautstärkeschwellenwert (VAD)
# Werte zwischen 0.001 (sehr empfindlich) und 0.1 (unempfindlich). Standard: 0.01
MIN_VOLUME_THRESHOLD_MIC=0.01
MIN_VOLUME_THRESHOLD_SLACK=0.01

# Filter für physische Audiogeräte (Teilstrings der Namen)
# Wenn leer, wird das System-Standardgerät verwendet.
INPUT_DEVICE_FILTER=
OUTPUT_DEVICE_FILTER=

# Namen für die virtuellen Audiogeräte (wichtig unter Linux PipeWire)
VIRTUAL_MIC_NAME=VoiceTL_Mic_Sink
VIRTUAL_SPK_NAME=VoiceTL_Slack_Out_Sink
